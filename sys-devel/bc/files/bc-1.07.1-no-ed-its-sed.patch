in MacaroniOS, everyone has sed. no one really has ed. tweak this minor script
to use sed instead of ed.

--- a/bc/fix-libmath_h
+++ b/bc/fix-libmath_h
@@ -1,9 +1,7 @@
-ed libmath.h <<EOS-EOS
+#!/bin/sh
+sed -i libmath.h -e '
 1,1s/^/{"/
-1,\$s/\$/",/
-2,\$s/^/"/
-\$,\$d
-\$,\$s/,\$/,0}/
-w
-q
-EOS-EOS
+1,$s/$/",/
+2,$s/^/"/
+$s/.*/0}/
+'
