+
+description="Perform initial detection of any filesystems"
+
+depend()
+{
+	before fsck localmount
+}
+
+start() {
+	ebegin "Detecting local filesystems"
+	if [ -x /sbin/btrfs ]; then
+		/sbin/btrfs device scan > /dev/null 2>&1
+	fi
+	eend 0
+}
